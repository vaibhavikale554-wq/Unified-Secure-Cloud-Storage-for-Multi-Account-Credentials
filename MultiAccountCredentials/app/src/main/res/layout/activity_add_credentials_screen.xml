    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="8dp"
        android:padding="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp">

            <!-- Back Button Icon -->

            <ImageView
                android:id="@+id/backicon_add"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/back_icon"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_alignParentStart="true"

                />

            <!-- Activity Name in the Middle -->
            <TextView
                android:id="@+id/application_name_add"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins"
                android:text="MultiCredentials"
                android:textColor="#333333"
                android:textSize="18sp" />


        </RelativeLayout>
    </androidx.cardview.widget.CardView>
    <ImageView
        android:id="@+id/application_logo_add"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/instagram_img"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Instagram Logo" />
    <androidx.cardview.widget.CardView
        android:layout_marginBottom="16dp"
        android:id="@+id/loading_card_main1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@android:color/white"
        android:visibility="visible"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        tools:layout_editor_absoluteX="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView

                android:id="@+id/note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/poppins"


                android:text="Note: Please add your Instagram credentials securely. Optional fields are marked."
                android:textColor="#E91E63"
                android:textSize="12sp" />


        </LinearLayout>
    </androidx.cardview.widget.CardView>

