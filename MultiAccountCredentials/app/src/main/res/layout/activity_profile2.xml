<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ProfileActivity">

  <!-- Top Header -->
  <LinearLayout
      android:id="@+id/relativeLayout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="1dp"
      android:background="@color/red_dark"
      android:elevation="8dp"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:padding="16dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <!-- Back Icon -->
    <ImageView
        android:id="@+id/backicon_profile"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginStart="5dp"
        android:contentDescription="Back"
        android:src="@drawable/backicon"
        android:tint="#FFFFFF" />

    <!-- Title -->
    <TextView
        android:id="@+id/application_name_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center"
        android:text="Profile"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />
  </LinearLayout>

  <!-- Profile Image -->
  <ImageView
      android:id="@+id/profile_image"
      android:layout_width="100dp"
      android:layout_height="100dp"
      android:layout_marginTop="32dp"
      android:layout_marginBottom="16dp"
      android:background="@drawable/person_profile_icon"
      android:scaleType="centerCrop"
      android:elevation="6dp"
      app:layout_constraintTop_toBottomOf="@id/relativeLayout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- Username Field -->
  <TextView
      android:id="@+id/username"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="Username: john_doe"
      android:textColor="#333333"
      android:textSize="18sp"
      android:layout_marginBottom="8dp"
      app:layout_constraintTop_toBottomOf="@id/profile_image"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- Full Name Field -->
  <TextView
      android:id="@+id/full_name"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Full Name: John Doe"
      android:textColor="#333333"
      android:textSize="18sp"
      android:layout_marginBottom="24dp"
      app:layout_constraintTop_toBottomOf="@id/username"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <!-- Reset Face Button -->
  <Button
      android:id="@+id/reset_face_button"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:backgroundTint="@color/red_dark"
      android:elevation="6dp"
      android:padding="12dp"
      android:text="RESET FACE"
      android:textColor="#FFFFFF"
      android:textStyle="bold"
      app:layout_constraintTop_toBottomOf="@id/full_name"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
