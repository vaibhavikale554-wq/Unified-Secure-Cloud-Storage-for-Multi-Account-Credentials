<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"> <!-- Adds padding around the dialog -->

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <!-- Popular Application Section Title -->
            <TextView
                android:id="@+id/popular_app_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Popular Application"
                android:textSize="20sp"
                android:textColor="@color/red_dark"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp" />

            <!-- Horizontal Icon List for Popular Applications -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <!-- Google Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/google_logo_bg"
                    android:layout_margin="8dp"
                    android:contentDescription="Google" />

                <!-- Facebook Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/facebook_logo"
                    android:layout_margin="8dp"
                    android:contentDescription="Facebook" />

                <!-- Twitter Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/x_logo"
                    android:layout_margin="8dp"
                    android:contentDescription="Twitter" />

                <!-- Snapchat Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/sanpchat_logo"
                    android:layout_margin="8dp"
                    android:contentDescription="Snapchat" />

                <!-- Instagram Icon -->
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/instagram_img"
                    android:layout_margin="8dp"
                    android:contentDescription="Instagram" />
            </LinearLayout>

            <!-- Add Manually Section Button -->
            <Button
                android:id="@+id/add_manually_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Manually"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/red_dark"
                android:textColor="@color/white"
                android:fontFamily="sans-serif"
                android:padding="12dp"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
